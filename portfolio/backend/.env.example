# Backend environment variables — copy to .env and fill in

# MongoDB Atlas connection string
# Get one free at https://www.mongodb.com/cloud/atlas/register
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/portfolio?retryWrites=true&w=majority

# Secret used to sign JWTs — make this long and random
JWT_SECRET=change_me_to_a_long_random_string

# Admin login (you)
# On first boot, the backend creates exactly one admin user with these creds.
# After that, these env vars are ignored; change the password via the /api/auth/change-password endpoint.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_before_deploying

# Comma-separated list of frontend origins allowed to call the API.
# For production, include your Vercel URL, e.g. https://my-portfolio.vercel.app
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# Port — Render sets this automatically; leave as is for local dev
PORT=4000
